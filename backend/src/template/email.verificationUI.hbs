<html lang="en">
  <head>
    <style>
      .verification {
        border: 1px solid black;
        background-color: rgb(47, 47, 226);
        padding: 2rem;
        color: white;
        font-weight: bolder;
        font-family: Arial, Helvetica, sans-serif;
      }
      .otp-container {
        background-color: black;
        color: white;
        padding: 2rem;
      }
    </style>
  </head>
  <body>
    <div>
      <div class="verification"><h2>Google Verification Code</h2></div>
      <div class="otp-container">
        <div><span>Hi {{name}},</span></div><br />
        <div>
          <span>
            We received a request to access your Google Account
            {{email}}
            through your email address. Your Google verification code is:
          </span>
        </div><br />
        <div style="text-align: center;">
          <h1>{{otp}}</h1>
        </div>
        <div>
          <p style="text-align: center;">This OTP will expire in
            {{minute}}
            minutes.</p>
        </div>
      </div>
    </div>
  </body>

</html>